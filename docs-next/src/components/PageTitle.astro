---
const { editUrl, entry } = Astro.locals.starlightRoute;
const sourceUrl = editUrl
  ? editUrl.toString().replace('/edit/', '/blob/')
  : 'https://github.com/modal-projects/training-gym';
const pageUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url).toString();

const currentPath = Astro.url.pathname;
const tutorialMatch = currentPath.match(/^\/tutorials\/(\w+)\/(\w+)\/?$/);
const notebookUrl = tutorialMatch
  ? `https://modal.com/notebooks/new/https://github.com/modal-projects/training-gym/blob/main/tutorials/${tutorialMatch[1]}/${tutorialMatch[2]}/${tutorialMatch[2]}.ipynb`
  : null;
---

<div class="tg-page-head">
  <div class="tg-page-head__actions print:hidden">
    {notebookUrl && (
      <a
        class="tg-action-button tg-action-button--primary"
        href={notebookUrl}
        target="_blank"
        rel="noopener noreferrer"
      >
        <img src="https://modal-cdn.com/open-in-modal.svg" alt="" style="height: 1rem; width: auto;" />
        Open in Modal
      </a>
    )}
    <a class="tg-action-button tg-action-button--ghost" href={sourceUrl}>View on GitHub</a>
    <button class="tg-action-button tg-copy-button" type="button" data-copy-page={pageUrl}>
      Copy page
    </button>
  </div>
  <h1 id="_top">{entry.data.title}</h1>
  {entry.data.description && <p class="tg-page-head__dek">{entry.data.description}</p>}
</div>

<script is:inline>
  document.addEventListener('click', async (event) => {
    if (!(event.target instanceof Element)) return;

    const button = event.target.closest('[data-copy-page]');
    if (!(button instanceof HTMLButtonElement)) return;

    const copyUrl = button.dataset.copyPage;
    if (!copyUrl) return;

    const originalLabel = button.textContent;

    try {
      await navigator.clipboard.writeText(copyUrl);
      button.textContent = 'Copied';
      button.classList.add('is-copied');
      window.setTimeout(() => {
        button.textContent = originalLabel;
        button.classList.remove('is-copied');
      }, 1600);
    } catch {
      button.textContent = copyUrl;
      button.classList.add('is-copied');
    }
  });
</script>
